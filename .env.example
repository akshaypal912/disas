# =============================================================================
# RESP-AI Disaster Response Platform — Environment Variables
# Copy this file to .env and fill in your actual values.
# FIX MEDIUM #16: All required variables are now documented here.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini API (used by server.ts for AI triage and severity classification)
# Get your key at: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OpenWeatherMap API (optional — WeatherPanel falls back to Open-Meteo if unset)
# Get your key at: https://openweathermap.org/api
# -----------------------------------------------------------------------------
VITE_OPENWEATHER_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL / Cloud SQL (used by src/db/index.ts via Drizzle ORM)
# For local dev without SSL set SQL_SSL=false
# -----------------------------------------------------------------------------
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
SQL_SSL=true

# -----------------------------------------------------------------------------
# Supabase (used by backend/app/db/supabase.py and backend/app/core/security.py)
# Find these in your Supabase project: Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# IBM watsonx (used by backend/app/services/watsonx.py)
# Get your credentials at: https://cloud.ibm.com/catalog/services/watson-machine-learning
# -----------------------------------------------------------------------------
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_ENDPOINT_URL=https://us-south.ml.cloud.ibm.com

# -----------------------------------------------------------------------------
# Firebase Admin SDK (used by src/lib/firebase-admin.ts for server-side token verification)
# Download your service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Set this to the absolute path of your downloaded service account JSON file.
# HIGH #9: firebase-admin requires this to verify tokens — projectId alone is not enough.
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# Socket.IO CORS (comma-separated list of allowed frontend origins)
# Defaults to localhost:3000 and localhost:5173 if not set.
# LOW #28: Restrict to your actual deployed frontend URL in production.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
